{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/supplier-sync",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/lemu-sync",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/cron/intelligence-check",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/learning-feedback",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/email-sync",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/offer-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/email-intelligence-summary",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/invoice-reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/bank-match",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/system-health-check",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/incoming-invoices",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/incoming-invoices-api",
      "schedule": "30 */6 * * *"
    }
  ]
}
